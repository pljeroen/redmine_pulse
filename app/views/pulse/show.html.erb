<%# Per-project health panel (HTML). Renders ONLY the precomputed HtmlPresenter
    view-model (@view). No scoring/timeline/AR access here — the view is a pure renderer. %>
<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'redmine_pulse', plugin: 'redmine_pulse' %>
<% end %>

<h2>
  <span class="pulse-rag pulse-rag-<%= @view.rag_chip.state %>"
        aria-label="<%= @view.rag_chip.aria_label %>"
        title="<%= @view.rag_chip.aria_label %>"><%= @view.rag_chip.word %></span>
  <%= @view.name %> &mdash; <%= t(:label_pulse) %>
</h2>

<p class="pulse-visibility-note"><%= @view.visibility_note %></p>

<%# A surfaced dangling-fallback warning. Rendered ONLY when the
    provider reported that an explicit / role-bound profile selection referenced an unpublished
    profile (scoring fell back to the system default). Precomputed on @view. %>
<% if @view.profile_warning %>
  <div class="flash warning pulse-profile-warning" role="alert"><%= @view.profile_warning %></div>
<% end %>

<%# The active-profile display + a no-JS switcher. Renders ONLY when the
    presenter surfaced a profile context (profile_options non-empty). The switcher is a plain
    GET form that re-requests the panel with ?profile_id=<id> (server-inline, no JS); the active
    option is pre-flagged selected. All state is precomputed on @view. %>
<% if @view.profile_options && !@view.profile_options.empty? %>
  <div class="pulse-profile-switcher">
    <% if @view.active_profile_name %>
      <span class="pulse-scored-under"><%= t(:label_pulse_scored_under) %>: <%= @view.active_profile_name %></span>
    <% end %>
    <%= form_tag({ controller: 'pulse', action: 'show', id: @view.identifier }, method: :get, class: 'pulse-profile-form') do %>
      <label for="pulse_profile_select"><%= t(:label_pulse_profile_switcher) %></label>
      <select id="pulse_profile_select" name="profile_id">
        <% @view.profile_options.each do |opt| %>
          <option value="<%= opt.value %>" <%= 'selected' if opt.selected %>><%= opt.label %></option>
        <% end %>
      </select>
      <%= submit_tag t(:label_pulse_apply), name: nil, class: 'pulse-profile-apply' %>
    <% end %>
  </div>
<% end %>

<%# A refresh control that POSTs to /pulse/refresh (CSRF-protected via
    button_to's hidden token). Lets the operator recompute the cached snapshot. %>
<div class="pulse-refresh">
  <%= button_to t(:label_pulse_refresh),
                { controller: 'pulse', action: 'refresh' },
                method: :post,
                params: { project_id: @view.identifier },
                class: 'pulse-refresh-button' %>
</div>

<%# The "Watch project health" opt-in toggle. Rendered ONLY for a real
    logged-in viewer (watch_offer); a plain CSRF-protected POST to pulse#watch / #unwatch that
    flips the viewer's own health-alert subscription. State is precomputed on @view
    — no AR/subscription access in this view. Clicking toggles the record the
    scan reads; it starts NO scan (the scan is rake-only). %>
<% if @view.watch_offer %>
  <div class="pulse-watch">
    <% if @view.watching %>
      <%= button_to t(:label_pulse_unwatch_health),
                    { controller: 'pulse', action: 'unwatch', id: @view.identifier },
                    method: :post, class: 'pulse-unwatch-button' %>
    <% else %>
      <%= button_to t(:label_pulse_watch_health),
                    { controller: 'pulse', action: 'watch', id: @view.identifier },
                    method: :post, class: 'pulse-watch-button' %>
    <% end %>
  </div>
<% end %>

<% if @view.no_data %>
  <%# R-A no-data state: render a distinct "No data" indicator, never a numeric score
      and never a nil crash. %>
  <p class="pulse-meta pulse-no-data">
    <span class="pulse-no-data-indicator"><%= @view.no_data_label %></span>
  </p>
<% else %>
  <p class="pulse-meta">
    <span class="pulse-score"><%= t(:label_pulse_health_score) %>: <%= @view.health_score %></span>
    <span class="pulse-concern"><%= t(:label_pulse_main_concern) %>: <%= @view.main_concern %></span>
    <span class="pulse-completeness"><%= t(:label_pulse_signal_completeness) %>: <%= @view.signal_completeness %></span>
    <span class="pulse-computed"><%= @view.computed_ago %></span>
  </p>

  <table class="list pulse-signals">
    <thead>
      <tr>
        <th><%= t(:label_pulse_signal) %></th>
        <th><%= t(:label_pulse_value) %></th>
        <th><%= t(:label_pulse_weight) %></th>
        <th><%= t(:label_pulse_contribution) %></th>
      </tr>
    </thead>
    <tbody>
      <% @view.signal_rows.each do |sig| %>
        <tr class="pulse-signal pulse-signal-<%= sig.key %> <%= sig.active ? 'active' : 'inactive' %>">
          <td class="pulse-signal-key">
            <%= sig.label %>
            <% if sig.drill_url %><a class="pulse-drill" href="<%= sig.drill_url %>">&rarr;</a><% end %>
          </td>
          <% if sig.active %>
            <td><%= sig.raw_value %></td>
            <td><%= sig.effective_weight %></td>
            <td><%= sig.contribution %></td>
          <% else %>
            <td class="pulse-enable-hint" colspan="3"><%= sig.enable_hint %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<div class="pulse-sparkline">
  <h3><%= t(:label_pulse_sparkline) %></h3>
  <%= render partial: 'pulse/sparkline', locals: { buckets: @view.sparkline } %>
</div>

<div class="pulse-milestones">
  <h3><%= t(:label_pulse_milestones) %></h3>
  <% if @view.milestones.empty? %>
    <p class="nodata"><%= t(:label_pulse_no_milestones) %></p>
  <% else %>
    <ul>
      <% @view.milestones.each do |mk| %>
        <li class="pulse-milestone"><%= mk[:name] %> &mdash; <%= mk[:due_date] %></li>
      <% end %>
    </ul>
  <% end %>
  <% if @view.gantt_url %>
    <p class="pulse-gantt-link">
      <a class="pulse-gantt" href="<%= @view.gantt_url %>"><%= t(:label_pulse_gantt_link) %></a>
    </p>
  <% end %>
</div>
