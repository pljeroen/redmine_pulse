<%# Pulse plugin settings (CA-23). Exposes EXACTLY the CA-23 field set, grouped into
    Enrichment / Weights / Thresholds / Windows. The deferred enrichment controls
    (DEC-12) are NOT rendered (COND-CA-02). risk_trackers is a native HTML multi-select
    (<select multiple>) populated with the project trackers — a working, no-JS control
    (D-CA-OQ02). The tracker option list is prepared OUTSIDE this view by
    PulseSettingsHelper#pulse_tracker_options (COND-A4-002 / Rule 18); the partial renders
    presenter/form state only — no scoring/AR logic.
    E1 settings-help: each field carries an inline <em class="info"> help paragraph
    (what it influences + shipped default) and each fieldset a group intro; all i18n-keyed
    (label_pulse_help_*). Presentation-only, no JS (HELP_SPEC presentation decision). %>
<% settings ||= @settings || {} %>
<% weights = (settings['weights'] || settings[:weights] || {}) %>
<% selected_trackers = Array(settings['risk_trackers'] || settings[:risk_trackers]).map(&:to_s) %>

<fieldset class="box tabular pulse-settings-enrichment">
  <legend><%= t(:label_pulse_settings_enrichment) %></legend>
  <p class="pulse-group-intro"><em class="info"><%= t(:label_pulse_help_group_enrichment) %></em></p>

  <p>
    <label for="settings_effort_field"><%= t(:label_pulse_effort_field) %></label>
    <input type="text" id="settings_effort_field" name="settings[effort_field]"
           value="<%= settings['effort_field'] %>" />
    <em class="info"><%= t(:label_pulse_help_effort_field) %></em>
  </p>

  <% if settings['effort_field'].to_s.strip.empty? %>
    <% effort_candidates = pulse_effort_field_candidates %>
    <% if effort_candidates.any? %>
      <p class="pulse-effort-candidates info">
        <%= t(:label_pulse_effort_field_detected) %>
        <% effort_candidates.each do |cf_name, cf_id| %>
          <span class="pulse-effort-candidate"><%= cf_name %> (id <%= cf_id %>)</span>
        <% end %>
      </p>
    <% end %>
  <% end %>

  <p>
    <label for="settings_risk_trackers"><%= t(:label_pulse_risk_trackers) %></label>
    <select id="settings_risk_trackers" name="settings[risk_trackers][]" multiple="multiple"
            size="6" class="pulse-risk-trackers">
      <% pulse_tracker_options.each do |tracker_name, tracker_id| %>
        <option value="<%= tracker_id %>" <%= 'selected' if selected_trackers.include?(tracker_id) %>>
          <%= tracker_name %>
        </option>
      <% end %>
    </select>
    <em class="info"><%= t(:label_pulse_help_risk_trackers) %></em>
  </p>

  <p>
    <label for="settings_blocked_status"><%= t(:label_pulse_blocked_status) %></label>
    <input type="text" id="settings_blocked_status" name="settings[blocked_status]"
           value="<%= settings['blocked_status'] %>" />
    <em class="info"><%= t(:label_pulse_help_blocked_status) %></em>
  </p>
</fieldset>

<% coverage_gap_enabled = %w[1 true yes on].include?(settings['enable_coverage_gap'].to_s.strip.downcase) %>
<fieldset class="box tabular pulse-settings-weights">
  <legend><%= t(:label_pulse_settings_weights) %></legend>
  <p class="pulse-group-intro"><em class="info"><%= t(:label_pulse_help_group_weights) %></em></p>
  <%# C2 (FC-C2-16): the optional coverage_gap weight is appended to the loop ONLY when the
      enable toggle is on — a CONDITIONAL weight input, never a speculative always-on control. %>
  <% weight_signals = [[:staleness, t(:label_pulse_weight_staleness)],
      [:progress, t(:label_pulse_weight_progress)],
      [:momentum, t(:label_pulse_weight_momentum)],
      [:risk_load, t(:label_pulse_weight_risk_load)],
      [:blocked_load, t(:label_pulse_weight_blocked_load)]] %>
  <% weight_signals += [[:coverage_gap, t(:label_pulse_weight_coverage_gap)]] if coverage_gap_enabled %>
  <% weight_signals.each do |sig, label| %>
    <p>
      <label for="settings_weight_<%= sig %>"><%= label %></label>
      <input type="text" id="settings_weight_<%= sig %>" name="settings[weights][<%= sig %>]"
             value="<%= weights[sig.to_s] || weights[sig] %>" />
      <em class="info"><%= t("label_pulse_help_weight_#{sig}") %></em>
    </p>
  <% end %>

  <p class="pulse-enable-coverage-gap">
    <label for="settings_enable_coverage_gap"><%= t(:label_pulse_enable_coverage_gap) %></label>
    <input type="hidden" name="settings[enable_coverage_gap]" value="0" />
    <input type="checkbox" id="settings_enable_coverage_gap" name="settings[enable_coverage_gap]"
           value="1" <%= 'checked' if coverage_gap_enabled %> />
    <em class="info"><%= t(:label_pulse_help_enable_coverage_gap) %></em>
  </p>
</fieldset>

<%# C4 (FR-C4-08): scoring-profile + role-binding management. Server-inline, no-JS, matching
    the existing settings idiom. Each persisted profile renders a name + the 5 weight inputs;
    one blank slot (__new__) lets the admin add one. The reserved "default" id is never an
    editable admin profile (it is synthetic). SettingsSanitizer validates + drops invalid
    entries at POST time; this view renders form state only (no scoring/AR logic). %>
<% pulse_profiles = (settings['pulse_profiles'] || settings[:pulse_profiles] || {}) %>
<% persisted_profiles = (pulse_profiles['profiles'] || pulse_profiles[:profiles] || {}) %>
<% persisted_bindings = (pulse_profiles['role_bindings'] || pulse_profiles[:role_bindings] || {}) %>
<% profile_weight_keys = %w[staleness progress momentum risk_load blocked_load] %>
<fieldset class="box tabular pulse-settings-profiles">
  <legend><%= t(:label_pulse_settings_profiles) %></legend>
  <p class="pulse-group-intro"><em class="info"><%= t(:label_pulse_help_group_profiles) %></em></p>

  <% profile_slots = persisted_profiles.to_a + [['__new__', {}]] %>
  <% profile_slots.each do |pid, entry| %>
    <% entry = (entry || {}) %>
    <% is_new = (pid == '__new__') %>
    <% pw = (entry['weights'] || entry[:weights] || {}) %>
    <div class="pulse-profile-entry">
      <p>
        <label><%= t(:label_pulse_profile_id) %></label>
        <% if is_new %>
          <input type="text" name="settings[pulse_profiles][profiles][__new__][id]" value="" />
        <% else %>
          <input type="text" name="settings[pulse_profiles][profiles][<%= pid %>][id]" value="<%= pid %>" readonly="readonly" />
        <% end %>
      </p>
      <p>
        <label><%= t(:label_pulse_profile_name) %></label>
        <input type="text" name="settings[pulse_profiles][profiles][<%= pid %>][name]"
               value="<%= entry['name'] || entry[:name] %>" />
      </p>
      <% profile_weight_keys.each do |sig| %>
        <p>
          <label><%= t("label_pulse_weight_#{sig}") %></label>
          <input type="text" name="settings[pulse_profiles][profiles][<%= pid %>][weights][<%= sig %>]"
                 value="<%= pw[sig] || pw[sig.to_sym] %>" />
        </p>
      <% end %>
    </div>
  <% end %>
  <p class="info pulse-profile-hint"><em class="info"><%= t(:label_pulse_profile_new) %></em></p>

  <div class="pulse-role-bindings">
    <p><strong><%= t(:label_pulse_role_bindings) %></strong></p>
    <% binding_slots = persisted_bindings.to_a + [['__new__', '']] %>
    <% binding_slots.each_with_index do |(rid, target), idx| %>
      <% is_new = (rid == '__new__') %>
      <% key = is_new ? "__new_#{idx}__" : rid %>
      <p class="pulse-role-binding-entry">
        <label><%= t(:label_pulse_role_binding_role_id) %></label>
        <input type="text" name="settings[pulse_profiles][role_bindings_pairs][<%= key %>][role_id]"
               value="<%= is_new ? '' : rid %>" />
        <label><%= t(:label_pulse_role_binding_profile_id) %></label>
        <input type="text" name="settings[pulse_profiles][role_bindings_pairs][<%= key %>][profile_id]"
               value="<%= is_new ? '' : target %>" />
      </p>
    <% end %>
    <p class="info"><em class="info"><%= t(:label_pulse_role_binding_new) %></em></p>
  </div>
</fieldset>

<fieldset class="box tabular pulse-settings-thresholds">
  <legend><%= t(:label_pulse_settings_thresholds) %></legend>
  <p class="pulse-group-intro"><em class="info"><%= t(:label_pulse_help_group_thresholds) %></em></p>
  <p>
    <label for="settings_rag_green_min"><%= t(:label_pulse_rag_green_min) %></label>
    <input type="number" id="settings_rag_green_min" name="settings[rag_green_min]"
           value="<%= settings['rag_green_min'] %>" min="0" max="100" />
    <em class="info"><%= t(:label_pulse_help_rag_green_min) %></em>
  </p>
  <p>
    <label for="settings_rag_amber_min"><%= t(:label_pulse_rag_amber_min) %></label>
    <input type="number" id="settings_rag_amber_min" name="settings[rag_amber_min]"
           value="<%= settings['rag_amber_min'] %>" min="0" max="100" />
    <em class="info"><%= t(:label_pulse_help_rag_amber_min) %></em>
  </p>
  <p>
    <label for="settings_on_track_threshold"><%= t(:label_pulse_on_track_threshold) %></label>
    <input type="number" id="settings_on_track_threshold" name="settings[on_track_threshold]"
           value="<%= settings['on_track_threshold'] %>" min="0" max="1" step="0.01" />
    <em class="info"><%= t(:label_pulse_help_on_track_threshold) %></em>
  </p>
</fieldset>

<%# C6 (FR-C6-08 auto-subscribe role + FR-C6-06 score_delta N): the two alert settings.
    Server-inline, no-JS, matching the existing settings idiom + PulseSettingsHelper. Both
    default OFF: a BLANK role select disables auto-subscribe; a blank/0 threshold disables the
    score-delta alert. SettingsSanitizer validates + drops invalid entries at POST time; this
    view renders prepared form/option state only (no scoring/AR logic — the givable-roles query
    lives in PulseSettingsHelper#pulse_alert_role_options, COND-A4-002 / Rule 18). These persist
    via the same plugin-settings path and are consumed ONLY by the rake scan composition root,
    never the request cycle (INV-ADDITIVE). %>
<fieldset class="box tabular pulse-settings-alerting">
  <legend><%= t(:label_pulse_settings_alerting) %></legend>
  <p class="pulse-group-intro"><em class="info"><%= t(:label_pulse_help_group_alerting) %></em></p>
  <p>
    <label for="settings_pulse_alert_auto_subscribe_role_id"><%= t(:label_pulse_alert_auto_subscribe_role_id) %></label>
    <select id="settings_pulse_alert_auto_subscribe_role_id" name="settings[pulse_alert_auto_subscribe_role_id]">
      <option value=""><%= t(:label_pulse_alert_auto_subscribe_disabled) %></option>
      <% selected_role_id = settings['pulse_alert_auto_subscribe_role_id'].to_s %>
      <% pulse_alert_role_options.each do |role_name, role_id| %>
        <option value="<%= role_id %>" <%= 'selected' if role_id == selected_role_id %>><%= role_name %></option>
      <% end %>
    </select>
    <em class="info"><%= t(:label_pulse_help_alert_auto_subscribe_role_id) %></em>
  </p>
  <p>
    <label for="settings_pulse_alert_score_delta_threshold"><%= t(:label_pulse_alert_score_delta_threshold) %></label>
    <input type="number" id="settings_pulse_alert_score_delta_threshold"
           name="settings[pulse_alert_score_delta_threshold]"
           value="<%= settings['pulse_alert_score_delta_threshold'] %>" min="0" step="0.1" />
    <em class="info"><%= t(:label_pulse_help_alert_score_delta_threshold) %></em>
  </p>
</fieldset>

<%# C7 (FR-C7-02/06/09): outbound webhooks. OFF by default — the shipped global list is empty,
    so the scan makes ZERO outbound HTTP until an endpoint is configured. Server-inline, no-JS,
    matching the settings idiom (mirrors the pulse_profiles multi-row pattern above). ALL
    configured GLOBAL endpoints render as editable indexed rows plus one blank "add" row; a
    per-row "remove" checkbox drops that endpoint. Each row persists as an Array<EndpointConfig>
    under settings[pulse_webhook_endpoints_global]; SettingsSanitizer validates each endpoint at
    POST time (bad url scheme / bad event_filter / redaction-of-a-required-field => reject, keep
    prior) and normalizes the boolean defaults. Safe defaults are per-endpoint overridable (SSRF /
    HTTPS-only / redaction). The HMAC secret is NEVER echoed (WH-06): a configured secret renders
    a BLANK password field with a "secret is set" hint + a hidden prior_index — leave blank to
    keep it, enter a value to replace. Endpoints are consumed by the rake scan composition root;
    the admin "Send test event" button is the SOLE request-cycle dispatch (admin-gated).
    Per-project endpoints are managed via the console/API and are PRESERVED untouched across a
    global-settings save (they are a separate settings key the sanitizer only touches when
    posted — this global form never emits them, so they are never dropped). %>
<% webhook_endpoints = Array(settings['pulse_webhook_endpoints_global']).select { |e| e.is_a?(Hash) } %>
<% webhook_event_types = %w[rag_transition dominant_change no_data_appeared score_delta] %>
<fieldset class="box tabular pulse-settings-webhooks">
  <legend><%= t(:label_pulse_settings_webhooks) %></legend>
  <p class="pulse-group-intro"><em class="info"><%= t(:label_pulse_help_group_webhooks) %></em></p>

  <%# Persisted endpoints (indexed rows) + one blank "add" row. is_new rows carry an add_row
      marker so the sanitizer silently skips an untouched blank slot (never a reject). %>
  <% webhook_rows = webhook_endpoints.each_with_index.map { |ep, i| [i.to_s, ep, i] } + [['__new__', {}, nil]] %>
  <% webhook_rows.each do |row_key, ep, prior_idx| %>
    <% is_new = (row_key == '__new__') %>
    <% base = "settings[pulse_webhook_endpoints_global][#{row_key}]" %>
    <% ep_filter = Array(ep['event_filter']).map(&:to_s) %>
    <div class="pulse-webhook-entry box">
      <% if is_new %>
        <input type="hidden" name="<%= base %>[add_row]" value="1" />
      <% else %>
        <input type="hidden" name="<%= base %>[prior_index]" value="<%= prior_idx %>" />
      <% end %>
      <p>
        <label><%= t(:label_pulse_webhook_url) %></label>
        <input type="url" name="<%= base %>[url]" value="<%= ep['url'] %>" placeholder="https://" />
      </p>
      <p>
        <label><%= t(:label_pulse_webhook_secret) %></label>
        <%# WH-06: never echo the stored secret. Blank password field; keep-on-blank. %>
        <input type="password" name="<%= base %>[secret]" value="" autocomplete="new-password" />
        <% if !is_new && !ep['secret'].to_s.strip.empty? %>
          <em class="info"><%= t(:label_pulse_webhook_secret_set) %></em>
        <% else %>
          <em class="info"><%= t(:label_pulse_webhook_secret_blank_keep) %></em>
        <% end %>
      </p>
      <p>
        <label><%= t(:label_pulse_webhook_enabled) %></label>
        <input type="hidden" name="<%= base %>[enabled]" value="0" />
        <input type="checkbox" name="<%= base %>[enabled]" value="1" <%= 'checked' if ep['enabled'] %> />
      </p>
      <p>
        <label><%= t(:label_pulse_webhook_event_filter) %></label>
        <% webhook_event_types.each do |et| %>
          <label class="pulse-webhook-event-filter">
            <input type="checkbox" name="<%= base %>[event_filter][]" value="<%= et %>"
                   <%= 'checked' if ep_filter.include?(et) %> /> <%= et %>
          </label>
        <% end %>
        <em class="info"><%= t(:label_pulse_help_webhook_event_filter) %></em>
      </p>
      <p>
        <label><%= t(:label_pulse_webhook_ssrf_override) %></label>
        <input type="hidden" name="<%= base %>[ssrf_override]" value="0" />
        <input type="checkbox" name="<%= base %>[ssrf_override]" value="1" <%= 'checked' if ep['ssrf_override'] %> />
      </p>
      <p>
        <label><%= t(:label_pulse_webhook_allow_http) %></label>
        <input type="hidden" name="<%= base %>[allow_http]" value="0" />
        <input type="checkbox" name="<%= base %>[allow_http]" value="1" <%= 'checked' if ep['allow_http'] %> />
      </p>
      <p>
        <label><%= t(:label_pulse_webhook_redaction) %></label>
        <input type="hidden" name="<%= base %>[redaction]" value="0" />
        <input type="checkbox" name="<%= base %>[redaction]" value="1"
               <%= 'checked' if ep['redaction'] && ep['redaction'] != false %> />
      </p>
      <% unless is_new %>
        <p>
          <label><%= t(:label_pulse_webhook_remove) %></label>
          <input type="hidden" name="<%= base %>[remove]" value="0" />
          <input type="checkbox" name="<%= base %>[remove]" value="1" />
        </p>
      <% end %>
    </div>
  <% end %>
  <p class="info pulse-webhook-hint"><em class="info"><%= t(:label_pulse_webhook_add) %></em></p>
</fieldset>

<fieldset class="box tabular pulse-settings-windows">
  <legend><%= t(:label_pulse_settings_windows) %></legend>
  <p class="pulse-group-intro"><em class="info"><%= t(:label_pulse_help_group_windows) %></em></p>
  <p>
    <label for="settings_h_stale"><%= t(:label_pulse_h_stale) %></label>
    <input type="number" id="settings_h_stale" name="settings[h_stale]"
           value="<%= settings['h_stale'] %>" min="1" />
    <em class="info"><%= t(:label_pulse_help_h_stale) %></em>
  </p>
  <p>
    <label for="settings_h_risk"><%= t(:label_pulse_h_risk) %></label>
    <input type="number" id="settings_h_risk" name="settings[h_risk]"
           value="<%= settings['h_risk'] %>" min="1" />
    <em class="info"><%= t(:label_pulse_help_h_risk) %></em>
  </p>
  <p>
    <label for="settings_h_blocked"><%= t(:label_pulse_h_blocked) %></label>
    <input type="number" id="settings_h_blocked" name="settings[h_blocked]"
           value="<%= settings['h_blocked'] %>" min="1" />
    <em class="info"><%= t(:label_pulse_help_h_blocked) %></em>
  </p>
  <p>
    <label for="settings_activity_window_days"><%= t(:label_pulse_activity_window_days) %></label>
    <input type="number" id="settings_activity_window_days" name="settings[activity_window_days]"
           value="<%= settings['activity_window_days'] %>" min="1" />
    <em class="info"><%= t(:label_pulse_help_activity_window_days) %></em>
  </p>
  <p>
    <label for="settings_momentum_activity_half"><%= t(:label_pulse_momentum_activity_half) %></label>
    <input type="number" id="settings_momentum_activity_half" name="settings[momentum_activity_half]"
           value="<%= settings['momentum_activity_half'] %>" min="0.1" step="0.1" />
    <em class="info"><%= t(:label_pulse_help_momentum_activity_half) %></em>
  </p>
  <p>
    <label for="settings_momentum_direction_bias"><%= t(:label_pulse_momentum_direction_bias) %></label>
    <input type="number" id="settings_momentum_direction_bias" name="settings[momentum_direction_bias]"
           value="<%= settings['momentum_direction_bias'] %>" min="0" max="0.5" step="0.01" />
    <em class="info"><%= t(:label_pulse_help_momentum_direction_bias) %></em>
  </p>
  <p>
    <label for="settings_snapshot_max_age_minutes"><%= t(:label_pulse_snapshot_max_age_minutes) %></label>
    <input type="number" id="settings_snapshot_max_age_minutes" name="settings[snapshot_max_age_minutes]"
           value="<%= settings['snapshot_max_age_minutes'] %>" min="0" step="1" />
    <em class="info"><%= t(:label_pulse_help_snapshot_max_age_minutes) %></em>
  </p>
</fieldset>
