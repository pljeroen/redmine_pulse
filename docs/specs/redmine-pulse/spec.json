  "core_model": {
    "signals": ["staleness", "progress", "momentum", "risk_load", "blocked_load"],
    "standard_field_active_set": ["staleness", "progress", "momentum", "blocked_load"],
    "enrichment_signals": ["risk_load"],
    "composite": "health_score = clamp(round_half_up(sum 100*w'_i*n_i), 0, 100); weights renormalize over active signals; contributions non-negative and sum to score",
    "rag": "green>=67, amber 34..66, red<34 (tunable)",
    "lenses": ["health", "at_risk", "stale", "done", "blocked"],
    "dominant_signal": "argmax w'_i*(1-n_i)",
    "transparency": "per-signal n/effective_weight/raw_value/contribution; reconstructs score (explainable)",
    "tunable": "weights + thresholds + horizons + activity window + signal mappings are plugin settings",
    "defaults": { "activity_window_days": 30, "rag_green_min": 67, "rag_amber_min": 34, "H_stale": 180, "H_risk": 50, "H_blocked": 20, "weights": { "staleness": 0.25, "progress": 0.25, "momentum": 0.20, "risk_load": 0.15, "blocked_load": 0.15 } }
  },
  "permission_model": {
    "access": "pulse project module + view_pulse read permission; 404 when not in Project.visible/nonexistent, 403 when visible-but-unpermitted",
    "data": "viewer-scoped via Project.visible / Issue.visible(user) (like Redmine's own aggregate reports); blocked_load counts only visible blockers (both endpoints visible)",
    "cache_key": "(project_id, visibility_context_id, snapshot_fingerprint); visibility_context_id = full resolved visibility predicate incl. user/group identity when issues_visibility is own/default"
  },
  "cache": {
    "design": "static aggregate snapshot (content-addressed) + per-request clock projection",
    "fingerprint_inputs": ["max_updated_on", "visible_issue_count", "latest_changeset_id", "blocker_fingerprint(relation_id+issue_from_id+is_closed+updated_on over visible blockers)", "version_due_date_set", "priority_enum_version", "settings_version_hash", "visibility_context_id"]
  },
  "constraints": ["INV-NO-INVENTED-DATES", "INV-READ-ONLY", "INV-PERMISSION-SAFE", "INV-DEGRADES-GRACEFULLY", "INV-DETERMINISTIC", "INV-EXPLAINABLE", "INV-DOMAIN-PURITY", "INV-OPEN"],
  "api": ["GET /pulse/portfolio.json", "GET /pulse/projects/:id.json"],
  "boundary": "Gantt editing out of scope (reuse redmine_canvas_gantt); this is the portfolio/health layer",
